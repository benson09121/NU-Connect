generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model tbl_academic_term {
  term_id                  Int                        @id @default(autoincrement())
  term_name                String                     @unique @db.VarChar(100)
  term_description         String?
  academic_year            String?                    @db.VarChar(20)
  start_date               DateTime                   @db.Date
  end_date                 DateTime                   @db.Date
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  created_by               String?                    @db.VarChar(200)
  tbl_user                 tbl_user?                  @relation(fields: [created_by], references: [user_id], onDelete: NoAction)
  tbl_organization_members tbl_organization_members[]
  tbl_term_payments        tbl_term_payments[]
}

model tbl_ai_conversation {
  conversation_id         BigInt           @id @default(autoincrement())
  owner_id                String           @db.VarChar(200)
  title                   String?          @db.VarChar(255)
  system_prompt           String?
  model                   String?          @default("deepseek-chat") @db.VarChar(100)
  temperature             Decimal?         @default(0.7) @db.Decimal(3, 2)
  top_p                   Decimal?         @default(1.0) @db.Decimal(3, 2)
  entity_type             ai_entity_type?  @default(general)
  entity_id               Int?
  summary                 String?
  is_global               Boolean?         @default(true)
  last_summary_message_id BigInt?
  is_archived             Boolean?         @default(false)
  created_at              DateTime?        @default(now()) @db.Timestamp(6)
  updated_at              DateTime?        @default(now()) @db.Timestamp(6)
  tbl_user                tbl_user         @relation(fields: [owner_id], references: [user_id], onDelete: NoAction)
  tbl_ai_message          tbl_ai_message[]

  @@index([owner_id, updated_at(sort: Desc)], map: "idx_owner_updated")
  @@index([entity_type, entity_id], map: "idx_scope")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model tbl_ai_message {
  message_id            BigInt              @id @default(autoincrement())
  conversation_id       BigInt
  role                  ai_role
  user_id               String?             @db.VarChar(200)
  content               String
  model                 String?             @db.VarChar(100)
  context_organizations Json?
  message_scope         ai_message_scope?   @default(current_view)
  meta                  Json?
  created_at            DateTime?           @default(now()) @db.Timestamp(6)
  tbl_ai_conversation   tbl_ai_conversation @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade, onUpdate: NoAction)
  tbl_user              tbl_user?           @relation(fields: [user_id], references: [user_id], onDelete: NoAction)

  @@index([conversation_id, message_id], map: "idx_conv_msg")
  @@index([conversation_id, created_at], map: "idx_conv_time")
  @@index([conversation_id, message_scope], map: "idx_message_scope")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tbl_application {
  application_id                                       Int                                       @id @default(autoincrement())
  organization_id                                      Int?
  cycle_number                                         Int?
  org_version_id                                       Int?
  submitted_org_name                                   String?                                   @db.VarChar(255)
  submitted_org_logo                                   String?                                   @db.VarChar(500)
  description                                          String?
  category                                             org_category?
  base_program_id                                      Int?
  student_id                                           String?                                   @db.VarChar(200)
  submitter_contact_no                                 String?                                   @db.VarChar(20)
  application_type                                     application_type
  period_id                                            Int
  applicant_user_id                                    String                                    @db.VarChar(200)
  status                                               status_pending_approved_rejected?         @default(Pending)
  docx_path                                            String?                                   @db.VarChar(500)
  pdf_path                                             String?                                   @db.VarChar(500)
  docx_generated_at                                    DateTime?                                 @db.Timestamp(6)
  pdf_generated_at                                     DateTime?                                 @db.Timestamp(6)
  document_generation_status                           String?                                   @default("pending")
  created_at                                           DateTime?                                 @default(now()) @db.Timestamp(6)
  updated_at                                           DateTime?                                 @default(now()) @db.Timestamp(6)
  tbl_user_tbl_application_applicant_user_idTotbl_user tbl_user                                  @relation("tbl_application_applicant_user_idTotbl_user", fields: [applicant_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  tbl_program                                          tbl_program?                              @relation(fields: [base_program_id], references: [program_id], onUpdate: NoAction)
  tbl_organization_version                             tbl_organization_version?                 @relation(fields: [org_version_id], references: [org_version_id], onUpdate: NoAction)
  tbl_renewal_cycle                                    tbl_renewal_cycle?                        @relation(fields: [organization_id, cycle_number], references: [organization_id, cycle_number], onUpdate: NoAction)
  tbl_application_period                               tbl_application_period                    @relation(fields: [period_id], references: [period_id], onDelete: NoAction, onUpdate: NoAction)
  tbl_user_tbl_application_student_idTotbl_user        tbl_user?                                 @relation("tbl_application_student_idTotbl_user", fields: [student_id], references: [user_id], onUpdate: NoAction)
  tbl_application_approval                             tbl_application_approval[]
  tbl_application_executives                           tbl_application_executives[]
  tbl_approval_process                                 tbl_approval_process[]
  tbl_application_approval_chain                       tbl_application_approval_chain[]
  tbl_organization_requirement_submission              tbl_organization_requirement_submission[]

  @@index([document_generation_status], map: "idx_document_status")
}

model tbl_application_approval {
  application_id       Int
  approval_id          Int
  tbl_application      tbl_application      @relation(fields: [application_id], references: [application_id], onDelete: NoAction, onUpdate: NoAction)
  tbl_approval_process tbl_approval_process @relation(fields: [approval_id], references: [approval_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([application_id, approval_id])
}

