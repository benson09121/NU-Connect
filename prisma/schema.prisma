  signature_path         String?                 @db.VarChar(255)
  remarks                String?
  endorsed_at            DateTime?               @db.Timestamp(6)
  received_at            DateTime?               @db.Timestamp(6)
  signed_at              DateTime?               @db.Timestamp(6)
  approved_at            DateTime?               @db.Timestamp(6)
  created_at             DateTime?               @default(now()) @db.Timestamp(6)
  tbl_application        tbl_application         @relation(fields: [application_id], references: [application_id], onDelete: Cascade, onUpdate: NoAction)
  tbl_role               tbl_role                @relation(fields: [approver_role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction)
  tbl_user               tbl_user                @relation(fields: [approver_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  tbl_application_period tbl_application_period? @relation(fields: [period_id], references: [period_id], onUpdate: NoAction)

  @@index([application_id, approval_order])
  @@index([approver_user_id, status])
  @@map("tbl_organization_approval_chain")
}

model tbl_user_esignature {
  user_id        String    @id @db.VarChar(200)
  signature_path String    @db.VarChar(255)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  tbl_user       tbl_user  @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model tbl_college_dean {
  id           Int         @id @default(autoincrement())
  college_id   Int
  dean_user_id String      @db.VarChar(200)
  is_active    Boolean     @default(true)
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  updated_at   DateTime?   @default(now()) @db.Timestamp(6)
  tbl_college  tbl_college @relation(fields: [college_id], references: [college_id], onDelete: NoAction, onUpdate: NoAction)
  tbl_user     tbl_user    @relation(fields: [dean_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([college_id, is_active])
}

