  tbl_organization_version tbl_organization_version? @relation(fields: [org_version_id], references: [org_version_id], onDelete: NoAction, onUpdate: NoAction)
}

model tbl_application_requirement {
  requirement_id                          Int                                       @id @default(autoincrement())
