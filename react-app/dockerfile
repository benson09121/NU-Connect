FROM nginx:latest

# Clear default content
RUN rm -rf /usr/share/nginx/html/*

# Copy application files
COPY /dist /usr/share/nginx/html

# Replace default config
RUN rm -rf /etc/nginx/conf.d/default.conf
RUN rm -rf /etc/nginx/nginx.conf
COPY nginx.conf /etc/nginx/nginx.conf
COPY default.conf /etc/nginx/conf.d/default.conf

# Create .well-known directory with proper ownership/permissions
RUN mkdir -p /usr/share/nginx/html/.well-known && \
    chown -R nginx:nginx /usr/share/nginx/html/.well-known && \
    chmod -R 755 /usr/share/nginx/html/.well-known

# Copy Microsoft verification file with explicit permissions
COPY --chown=nginx:nginx microsoft-identity-association.json /usr/share/nginx/html/.well-known/

# Optional certificates directory setup
RUN mkdir -p /usr/share/nginx/html/certificates && \
    chown -R nginx:nginx /usr/share/nginx/html/certificates && \
    chmod -R 755 /usr/share/nginx/html/certificates

# Requirements directory setup
RUN mkdir -p /usr/share/nginx/html/requirements && \
    chown -R nginx:nginx /usr/share/nginx/html/requirements && \
    chmod -R 755 /usr/share/nginx/html/requirements

# Applications directory setup
RUN mkdir -p /usr/share/nginx/html/applications && \
    chown -R nginx:nginx /usr/share/nginx/html/applications && \
    chmod -R 755 /usr/share/nginx/html/applications

# Events directory setup
RUN mkdir -p /usr/share/nginx/html/events && \
    chown -R nginx:nginx /usr/share/nginx/html/events && \
    chmod -R 755 /usr/share/nginx/html/events

# Organizations directory for transactions files
RUN mkdir -p /usr/share/nginx/html/organizations && \
    chown -R nginx:nginx /usr/share/nginx/html/organizations && \
    chmod -R 755 /usr/share/nginx/html/organizations

# E-Signatures directory setup
RUN mkdir -p /usr/share/nginx/html/esignatures && \
    chown -R nginx:nginx /usr/share/nginx/html/esignatures && \
    chmod -R 755 /usr/share/nginx/html/esignatures

# Approval signatures directory setup
RUN mkdir -p /usr/share/nginx/html/approval-signatures && \
    chown -R nginx:nginx /usr/share/nginx/html/approval-signatures && \
    chmod -R 755 /usr/share/nginx/html/approval-signatures

# Ensure root directory permissions
RUN chmod -R 755 /usr/share/nginx/html